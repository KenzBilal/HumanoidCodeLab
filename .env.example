# ────────────────────────────────────────────────────────────────
# Humanoid Code Lab — Environment Variables
# ────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your secrets.
# NEVER commit your .env file — it is already in .gitignore.
# ────────────────────────────────────────────────────────────────

# ── AI Provider API Keys ─────────────────────────────────────────
# You only need to set the key for the provider you want to use.
# These are stored securely in the OS native keychain via Electron
# safeStorage — they are NOT persisted to localStorage.

# Google Gemini (Gemini 2.0 Flash)
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your_google_gemini_api_key"

# OpenAI (GPT-4o)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY="your_openai_api_key"

# Anthropic Claude (Claude 3.7 Sonnet)
# Get your key from: https://console.anthropic.com/keys
ANTHROPIC_API_KEY="your_anthropic_api_key"
