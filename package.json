{
  "name": "humanoid-code-lab",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "author": "KenzBilal",
  "description": "A 3D humanoid robot programming lab with scripting, animation editor, and AI generation",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "vite build && electron .",
    "dist": "vite build && electron-builder --linux",
    "dist:win": "vite build && electron-builder --win",
    "dist:mac": "vite build && electron-builder --mac",
    "publish": "vite build && electron-builder --linux -p always",
    "clean": "rm -rf dist dist-electron release",
    "lint": "tsc --noEmit",
    "test": "vitest run"
  },
  "build": {
    "appId": "com.humanoidcodelab.app",
    "productName": "Humanoid Code Lab",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "!node_modules/**/{test,__tests__,tests}/**"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "KenzBilal",
        "repo": "HumanoidCodeLab"
      }
    ],
    "linux": {
      "target": "AppImage",
      "category": "Development",
      "icon": "dist/favicon.ico"
    },
    "win": {
      "target": "nsis",
      "icon": "dist/favicon.ico"
    },
    "mac": {
      "target": "dmg"
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@google/genai": "^1.29.0",
    "@monaco-editor/react": "^4.7.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "electron-updater": "^6.8.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "openai": "^6.33.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-resizable-panels": "^4.8.0",
    "serialport": "^13.0.0",
    "three": "^0.183.2",
    "vite": "^6.2.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/three": "^0.183.1",
    "autoprefixer": "^10.4.21",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^4.1.2"
  }
}
